{
  "id": "chargepoint",
  "name": {
    "en": "Charge point",
    "nl": "Laadpunt"
  },
  "images": {
    "large": "/drivers/chargepoint/assets/images/large.png",
    "small": "/drivers/chargepoint/assets/images/small.png"
  },
  "class": "evcharger",
  "energy": {
    "evCharger": true,
    "meterPowerImportedCapability": "meter_power"
  },
  "capabilities": [ "evcharger_charging_state", "evcharger_charging" ],
  "repair": [
    {
      "id": "login"
    }],
  "pair": [
    {
      "id": "login"
    },
    {
      "id": "discover_chargepoints",
      "template": "loading",
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "device_settings"
      },
      "options": {
        "singular": true
      }
    },
    {
      "id": "device_settings"
    },
    {
      "id": "error"
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Car settings",
        "nl": "Auto instellingen"
      },
      "children": [
        {
          "id": "charge_capacity",
          "type": "number",
          "label": {
            "en": "Charge capacity (kW)",
            "nl": "Laad vermogen (kW)"
          },
          "value": 3.3,
          "min": 0
        }
      ]
    },
    {
        "id": "card_printedNumber",
        "type": "text",
        "label": {
          "en": "The printed number of your charge card (authorized)",
          "nl": "Het nummer afgedrukt op de laadpas (geauthoriseerd)"
        }
    },
    {
      "id": "include_power",
      "type": "checkbox",
      "label": {
        "en": "Include Charge capacity in Energy",
        "nl": "Laad vermogen in Energie weergeven"
      },
      "value": true
    },
    {
      "id": "pause_on_stop",
      "type": "checkbox",
      "label": {
        "en": "Pause session on stop (instead of stopping it)",
        "nl": "Sessie pauzeren bij stoppen (in plaats van beëindigen)"
      },
      "hint": {
        "en": "ON: blocks the session so it can be resumed without RFID card (useful for automatic energy management). OFF: stops the session completely, RFID card required to start again (default, same as v4.1.14).",
        "nl": "AAN: pauzeert de sessie zodat deze hervat kan worden zonder laadpas (handig voor automatisch energiebeheer). UIT: beëindigt de sessie volledig, laadpas nodig om opnieuw te starten (standaard, zelfde als v4.1.14)."
      },
      "value": false
    }
  ]
}